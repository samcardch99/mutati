---
interface Props {
    phrase: string;
    class?: string;
    delay?: number;
}

const { phrase, class: className, delay = 0 } = Astro.props;

// Pre-procesamos el HTML
const formattedPhrase = phrase.replace(
    /\*(.*?)\*/g,
    '<b class="font-bold">$1</b>',
);
---

<span
    class={`reveal-type-container inline-block ${className}`}
    data-delay={delay}
>
    <span class="gsap-hybrid-text invisible block" set:html={formattedPhrase} />
</span>

<style is:global>
    /* Estilos críticos para evitar saltos de línea durante el split */
    .reveal-type-container {
        vertical-align: top;
        /* Evita que el texto baile horizontalmente si las letras de glitch miden distinto */
        font-kerning: none;
    }

    .gsap-hybrid-text div {
        /* Asegura que las líneas creadas por GSAP no colapsen */
        display: block;
        position: relative;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { SplitText } from "gsap/SplitText";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(SplitText, ScrollTrigger);

    const glitchChars = ["h", "x", "t", "y"];
    const TOTAL_DURATION = 1.0;

    const playGlitch = (charElement: HTMLElement, finalChar: string) => {
        if (finalChar === " " || !finalChar) return;

        const tl = gsap.timeline();
        tl.to(charElement, {
            duration: 0.04,
            onStart: () => {
                charElement.textContent =
                    glitchChars[Math.floor(Math.random() * 4)];
            },
        })
            .to(charElement, {
                duration: 0.04,
                onStart: () => {
                    charElement.textContent =
                        glitchChars[Math.floor(Math.random() * 4)];
                },
            })
            .to(charElement, {
                duration: 0.04,
                onComplete: () => {
                    charElement.textContent = finalChar;
                },
            });
    };

    const elements = document.querySelectorAll(".gsap-hybrid-text");

    elements.forEach((el) => {
        const container = el.parentElement as HTMLElement;
        const startDelay = parseFloat(container?.dataset.delay || "0");

        // Realizamos el split
        const split = new SplitText(el as HTMLElement, {
            type: "lines,chars",
            linesClass: "line-wrapper overflow-hidden",
        });

        // Una vez hecho el split, hacemos visible el elemento
        gsap.set(el, { autoAlpha: 1 });

        const charCount = split.chars.length;
        const individualDuration = 0.5;
        const staggerTime =
            charCount > 1
                ? (TOTAL_DURATION - individualDuration) / (charCount - 1)
                : 0;

        gsap.from(split.chars, {
            yPercent: 105, // Un poco más de 100 para asegurar limpieza
            duration: individualDuration,
            delay: startDelay,
            ease: "power4.out",
            stagger: {
                each: Math.max(staggerTime, 0.01),
                onStart: function () {
                    const charElement = (this as any).targets()[0];
                    const finalChar = charElement.textContent;
                    playGlitch(charElement, finalChar);
                },
            },
            scrollTrigger: {
                trigger: el,
                start: "top 95%",
                toggleActions: "play none none none",
            },
        });
    });
</script>
