---
interface Props {
    phrase: string;
    class?: string;
    mode?: "lines" | "words" | "chars";
    delay?: number;
}

const { phrase, class: className, mode = "lines", delay = 0 } = Astro.props;
---

<div
    class={`gsap-text-container ${className}`}
    data-split-mode={mode}
    data-delay={delay}
>
    <span class="gsap-reveal-text">{phrase}</span>
</div>

<style>
    .gsap-reveal-text {
        visibility: hidden;
        display: block; /* Forzamos bloque para que el cálculo de líneas sea preciso */
        width: 100%;
    }

    /* Evitamos que las palabras se rompan a mitad de camino */
    :global(.word-parent) {
        display: inline-block;
        white-space: nowrap;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { SplitText } from "gsap/SplitText";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(SplitText, ScrollTrigger);

    const containers = document.querySelectorAll("[data-split-mode]");

    containers.forEach((container) => {
        const mode = container.getAttribute("data-split-mode") || "lines";
        const startDelay = parseFloat(
            (container as HTMLElement).dataset.delay || "0",
        );
        const el = container.querySelector(".gsap-reveal-text");

        if (!el) return;

        // Revelamos antes de hacer el split para que los cálculos de posición sean correctos
        gsap.set(el, { autoAlpha: 1 });

        const split = new SplitText(el, {
            type: mode as any,
            // Agregamos una clase base de GSAP que ayuda a mantener el estilo
            linesClass: "line-child",
            wordsClass: "word-child",
            charsClass: "char-child",
        });

        let animationProps: gsap.TweenVars = {};
        let target: any[] = [];

        if (mode === "lines") {
            // "Wrapping" manual para efecto de máscara
            split.lines.forEach((line) => {
                const wrapper = document.createElement("div");
                wrapper.className = "line-parent";
                wrapper.style.overflow = "hidden";
                line.parentNode?.insertBefore(wrapper, line);
                wrapper.appendChild(line);
            });
            target = split.lines;
            animationProps = { yPercent: 100, stagger: 0.2 };
        } else if (mode === "words") {
            target = split.words;
            animationProps = { opacity: 0, y: 20, stagger: 0.05 };
        } else if (mode === "chars") {
            target = split.chars;
            animationProps = { opacity: 0, y: 10, stagger: 0.02 };
        }

        gsap.from(target, {
            ...animationProps,
            delay: startDelay,
            duration: mode === "words" ? 0.8 : 0.5,
            ease: "power2.out",
            scrollTrigger: {
                trigger: container, // Usamos el contenedor como trigger para mayor estabilidad
                start: "top 95%",
                toggleActions: "play none none none",
            },
        });

        // RE-CÁLCULO (Opcional pero recomendado)
        // Si la ventana cambia de tamaño, el split de líneas puede romperse
        window.addEventListener("resize", () => {
            if (mode === "lines") {
                split.revert();
                // Aquí podrías volver a ejecutar la lógica si es crítico
            }
        });
    });
</script>
