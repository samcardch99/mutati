---
import { Image } from "astro:assets";
import projectsData from "../data/projects.json";
import TypeWriter from "./helpers/TypeWriter.astro";
import TextReveal from "./helpers/TextReveal.astro";
import RightArrow from "../assets/right_arrow.svg";

interface ImageModule {
  default: ImageMetadata;
}

const allPortadas = import.meta.glob<ImageModule>(
  "../assets/Projects/*/Portada/*.{jpeg,jpg,png,gif,webp}",
);
---

<section
  id="projects"
  data-nav-color="text-light"
  class="min-h-screen w-full bg-black text-light px-6 md:px-16 lg:px-32 pt-28 md:pt-40 pb-20 flex flex-col lg:flex-row items-center justify-center overflow-hidden"
>
  <div
    class="w-full lg:h-[70vh] flex flex-col lg:flex-row justify-between items-center lg:items-center gap-12 md:gap-16 lg:gap-20"
  >
    <div
      class="flex flex-col justify-center items-start lg:order-2 w-full md:max-w-2xl lg:max-w-[45%] relative gap-8 md:gap-10"
    >
      <div class="flex flex-col gap-6 md:gap-8 w-full">
        <h2
          class="text-3xl md:text-5xl lg:text-6xl font-normal leading-tight max-w-4/5 lg:max-w-3/5"
        >
          <TypeWriter
            duration={0.03}
            phrase="Discover *The Excellence* Behind Every *Detail* Of Our *Creations*"
          />
        </h2>

        <div
          class="h-0.5 bg-light lg:bg-white transition-all duration-700
                 w-24
                 hidden lg:block
                 md:w-full
                 lg:w-[70%]"
        >
        </div>
      </div>

      <div
        class="text-lg md:text-2xl lg:text-3xl lg:font-light leading-relaxed"
      >
        <TextReveal
          class="text-balance"
          phrase="Mutati manages a limited record of two annual interior projects. Each cabin is a bespoke architectural asset designed under FAA certification standards and reserved exclusively for the Holder."
          delay={1.3}
        />
      </div>
    </div>

    <div
      class="w-full h-full max-w-full md:max-w-2xl lg:max-w-1/2 flex flex-col items-center lg:order-1"
    >
      <div
        class="swiper mx-0! w-full h-fit aspect-square md:aspect-video lg:aspect-square relative overflow-hidden rounded-sm"
      >
        <div class="swiper-wrapper">
          {
            projectsData.map((project) => {
              const portadaPath = `../assets/Projects/${project.id}/Portada/1.jpg`;

              return (
                <div class="swiper-slide relative flex items-center justify-center group overflow-hidden">
                  <a
                    href={`/projects/${project.id}`}
                    class="no-style absolute inset-0 bg-black/0 group-hover:bg-black/60 group-[.is-active]:bg-black/60 transition-all duration-500 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 group-[.is-active]:opacity-100 z-20 cursor-pointer"
                  >
                    <span class="text-light text-2xl md:text-3xl lg:text-4xl font-light italic tracking-widest border-b border-light/30 pb-2">
                      View Project
                    </span>
                    <span class="text-sm md:text-base lg:text-lg uppercase tracking-[0.3em] mt-4 text-bone/60">
                      {project.title.replace(/\*/g, "")}
                    </span>
                  </a>

                  {allPortadas[portadaPath] && (
                    <Image
                      src={allPortadas[portadaPath]()}
                      width={1920}
                      height={1080}
                      quality={60}
                      alt={project.title.replace(/\*/g, "")}
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 group-[.is-active]:scale-110"
                    />
                  )}
                </div>
              );
            })
          }
        </div>

        <div
          class="md:flex hidden swiper-button-prev-custom absolute mix-blend-difference left-6 top-1/2 -translate-y-1/2 z-30 cursor-pointer text-light/70 hover:text-light transition-all"
        >
          <RightArrow class="w-10 h-10 lg:w-16 lg:h-16 rotate-180" />
        </div>
        <div
          class="md:flex hidden swiper-button-next-custom absolute mix-blend-difference right-6 top-1/2 -translate-y-1/2 z-30 cursor-pointer text-light/70 hover:text-light transition-all"
        >
          <RightArrow class="w-10 h-10 lg:w-16 lg:h-16" />
        </div>
      </div>

      <div class="swiper-pagination mt-10 md:mt-12 relative!"></div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Pagination, Autoplay, Navigation } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/pagination";
  import "swiper/css/navigation";

  const swiperInstance = new Swiper(".swiper", {
    modules: [Pagination, Autoplay, Navigation],
    pagination: { el: ".swiper-pagination", clickable: true },
    navigation: {
      nextEl: ".swiper-button-next-custom",
      prevEl: ".swiper-button-prev-custom",
    },
    slidesPerView: 1,
    spaceBetween: 30,
    loop: true,
    autoplay: {
      delay: 6000,
      disableOnInteraction: false,
    },
  });

  const swiperContainer = document.querySelector(".swiper");
  if (swiperContainer && window.innerWidth < 1024) {
    let timeoutId: ReturnType<typeof setTimeout> | undefined;
    const animateActiveSlide = () => {
      if (timeoutId) clearTimeout(timeoutId);
      document
        .querySelectorAll(".swiper-slide")
        .forEach((slide) => slide.classList.remove("is-active"));
      const activeSlide = swiperInstance.slides[swiperInstance.activeIndex];
      if (activeSlide) {
        activeSlide.classList.add("is-active");
        timeoutId = setTimeout(
          () => activeSlide.classList.remove("is-active"),
          2500,
        );
      }
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateActiveSlide();
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 },
    );

    observer.observe(swiperContainer);
    swiperInstance.on("slideChangeTransitionStart", animateActiveSlide);
  }
</script>

<style>
  :global(.swiper-pagination-bullet) {
    background-color: #e8e3e1 !important;
    width: 1rem !important;
    height: 1rem !important;
    margin: 0 0.6rem !important;
    opacity: 0.5;
    transition: all 0.3s ease;
  }
  @media (max-width: 768px) {
    :global(.swiper-pagination-bullet) {
      width: 0.7rem !important;
      height: 0.7rem !important;
      margin: 0 0.4rem !important;
    }
  }
  @media (max-width: 1024px) {
    :global(.swiper-pagination-bullet) {
      width: 0.8rem !important;
      height: 0.8rem !important;
      margin: 0 0.5rem !important;
    }
  }

  :global(.swiper-pagination-bullet-active) {
    background-color: white !important;
    opacity: 1;
    transform: scale(1.2);
  }

  .swiper-slide {
    aspect-ratio: 1 / 1;
  }

  @media (min-width: 768px) {
    .swiper-slide {
      aspect-ratio: 16 / 9;
    }
  }

  @media (min-width: 1024px) {
    .swiper-slide {
      aspect-ratio: 1 / 1;
    }
  }
</style>
