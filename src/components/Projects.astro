---
import { Image } from "astro:assets";
// Importación de datos y componentes
import projectsData from "../data/projects.json";
import TypeWriter from "./helpers/TypeWriter.astro";
import TextReveal from "./helpers/TextReveal.astro";

interface ImageModule {
  default: ImageMetadata;
}

// 1. Cargamos todas las imágenes de portada del directorio Projects
const allPortadas = import.meta.glob<ImageModule>(
  "../assets/Projects/*/Portada/*.{jpeg,jpg,png,gif,webp}",
);
---

<section
  class="min-h-screen w-full bg-black text-light px-6 lg:px-32 pt-36 pb-20 flex flex-col lg:flex-row items-center"
>
  <div
    class="w-full h-[70vh] flex flex-col lg:flex-row justify-between items-end gap-10 lg:gap-16"
  >
    <div
      class="flex flex-col justify-end items-start gap-10 lg:order-2 lg:max-w-2/5 lg:pb-12 relative h-full"
    >
      <div
        class="flex flex-col gap-10 lg:absolute lg:top-1/2 lg:-translate-y-1/2 w-full"
      >
        <h2 class="text-2xl lg:text-6xl max-w-4/5 font-normal">
          <TypeWriter
            duration={0.03}
            phrase="Discover *The Excellence* Behind Every *Detail* Of Our *Creations*"
          />
        </h2>
        <div class="h-0.5 w-[70%] self-start bg-light lg:bg-brown"></div>
      </div>

      <div
        class="text-lg lg:text-3xl lg:font-light lg:max-w-full lg:leading-normal"
      >
        <TextReveal
          class="text-balance"
          phrase="Mutati manages a limited record of two annual interior projects. Each cabin is a bespoke architectural asset designed under FAA certification standards and reserved exclusively for the Holder."
          delay={1.3}
        />
      </div>
    </div>

    <div
      class="w-full h-full max-w-4xl lg:max-w-1/2 flex flex-col items-center lg:order-1"
    >
      <div class="swiper mx-0! w-full h-fit aspect-square">
        <div class="swiper-wrapper">
          {
            projectsData.map((project) => {
              // Construimos la ruta de la portada para este proyecto específico
              const portadaPath = `../assets/Projects/${project.id}/Portada/1.jpg`;

              return (
                <div class="swiper-slide relative flex items-center justify-center group overflow-hidden">
                  {/* Link dinámico con efecto de hover profesional */}
                  <a
                    href={`/projects/${project.id}`}
                    class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-500 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 z-20 cursor-pointer"
                  >
                    <span class="text-light text-4xl font-light italic tracking-widest border-b border-light/30 pb-2">
                      View Project
                    </span>
                    <span class="text-lg uppercase tracking-[0.3em] mt-4 text-bone/60">
                      {project.title.replace(/\*/g, "")}
                    </span>
                  </a>

                  {allPortadas[portadaPath] && (
                    <Image
                      src={allPortadas[portadaPath]()}
                      width={1920}
                      height={1080}
                      quality={60}
                      alt={project.title}
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    />
                  )}
                </div>
              );
            })
          }
        </div>
      </div>
      <div class="swiper-pagination mt-6 relative!"></div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Pagination, Autoplay, EffectFade } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/pagination";

  new Swiper(".swiper", {
    modules: [Pagination, Autoplay],
    pagination: { el: ".swiper-pagination", clickable: true },
    slidesPerView: 1,
    spaceBetween: 20,
    loop: true,
    autoplay: {
      delay: 5000,
      disableOnInteraction: false,
    },
  });
</script>

<style>
  :global(.swiper-pagination-bullet) {
    background-color: #e8e3e1 !important;
    @media (min-width: 1024px) {
      aspect-ratio: 1/1 !important;
      width: 0.75rem !important;
      margin-left: 0.75rem !important;
      height: auto !important;
    }
  }
  :global(.swiper-pagination-bullet-active) {
    background-color: white !important;
  }

  .swiper-slide {
    aspect-ratio: 16 / 9; /* Mantiene la proporción elegante para jets */
  }
</style>
