---
import RevealType from "./helpers/RevealType.astro";
import TextReveal from "./helpers/TextReveal.astro";
---

<section
  id="about-section"
  data-nav-color="text-brown"
  class="h-full w-full px-6 lg:px-24 flex flex-col gap-6 lg:gap-12 justify-center text-lg z-100"
>
  <h2 class="sr-only">About Mutati Design</h2>
  <p>
    <TextReveal
      class="font-medium text-xl lg:text-4xl leading-snug lg:max-w-1/2 text-brown"
      phrase="Mutati is a luxury firm specializing in private jet interior design and bespoke aviation architecture. We blend high-end design with FAA-certified engineering to transform every aircraft cabin into a sophisticated space, recognizing that a private jet is not merely transportation, but a registered architectural asset."
      delay={0.3}
    />
  </p>
  <a
    href="/about"
    class="text-button_text text-xl font-medium text-light bg-brown rounded-full px-6 py-2 lg:px-12 lg:py-4 lg:text-4xl w-fit"
    >See More</a
  >
</section>
