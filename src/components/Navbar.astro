---
import Logo from "../assets/logo.svg";
import Logo_Large from "../assets/logo_large.svg";
import BurgerMenu from "../assets/burger_menu.svg";
---

<nav
  id="main-nav"
  class="group w-full text-brown fixed top-0 z-100 transition-colors duration-500"
>
  <div
    class="absolute inset-0 backdrop-blur-sm [mask:linear-gradient(to_bottom,black_80%,transparent_100%)] -z-10 pointer-events-none"
  >
  </div>

  <div
    class="flex justify-between items-center px-6 lg:px-24 lg:pt-12 pt-8 pb-6 relative z-200"
  >
    <button class="menu-toggle cursor-pointer lg:hidden z-110">
      <svg
        width="56"
        height="16"
        viewBox="0 0 56 16"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="w-12 h-auto"
      >
        <rect class="line-1" width="56" height="3" rx="1.5" fill="currentColor"
        ></rect>
        <rect
          class="line-2"
          y="13"
          width="56"
          height="3"
          rx="1.5"
          fill="currentColor"></rect>
      </svg>
    </button>
    <a
      href="/ "
      class="text-current absolute lg:order-1 lg:relative lg:left-auto lg:translate-x-0 left-1/2 -translate-x-1/2 w-14 h-14 lg:w-20 lg:h-20"
    >
      <Logo />
    </a>
    <a
      id="nav-logo-center"
      class="hidden lg:block absolute invisible left-1/2 -translate-x-1/2 lg:w-[120px] 2xl-custom:w-[256px] 3xl-custom:w-[320px] text-inherit self-center transition-opacity"
    >
      <Logo_Large />
    </a>

    <div class="flex items-center lg:gap-12 lg:order-2">
      <a
        href="/contact"
        class="bg-current block px-6 py-2 lg:px-10 lg:py-3 rounded-full text-lg lg:text-3xl font-medium"
      >
        <span
          class="text-light group-[.text-light]:text-red transition-colors duration-500"
          >APPLY</span
        >
      </a>
      <button class="menu-toggle cursor-pointer hidden lg:block z-110">
        <svg
          width="56"
          height="16"
          viewBox="0 0 56 16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="w-16 h-auto"
        >
          <rect
            class="line-1"
            width="56"
            height="3"
            rx="1.5"
            fill="currentColor"></rect>
          <rect
            class="line-2"
            y="13"
            width="56"
            height="3"
            rx="1.5"
            fill="currentColor"></rect>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="menu-overlay"
    class="fixed inset-0 bg-[#E8E3E1] hidden flex-col items-center justify-end lg:justify-between z-105"
  >
    <div
      class="absolute top-1/2 -translate-y-1/2 lg:relative lg:top-auto lg:translate-y-0 flex flex-col items-center gap-10 lg:gap-14 lg:pt-48"
    >
      <a
        href="/"
        class="menu-link text-3xl lg:text-5xl font-light tracking-tight text-brown/90"
      >
        Home
      </a>
      <a
        href="/about"
        class="menu-link text-3xl lg:text-5xl font-light tracking-tight text-brown/90"
      >
        About
      </a>
      <a
        href="/#projects"
        class="menu-link text-3xl lg:text-5xl font-light tracking-tight text-brown/90"
      >
        Projects
      </a>
      <a
        href="/contact"
        class="menu-link text-3xl lg:text-5xl font-light tracking-tight text-brown/90"
      >
        Contact
      </a>
    </div>

    <div class="w-full px-6 lg:px-24 overflow-hidden">
      <div class="w-full border-t-2 border-brown/20 pt-10 overflow-hidden">
        <div class="menu-footer-logo w-full translate-y-full">
          <Logo_Large class="w-full pb-6 lg:pb-10" />
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  #nav-logo-center {
    transform-origin: center center;
    overflow: visible;
  }

  .line-1,
  .line-2 {
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }

  .menu-toggle.is-active .line-1 {
    transform: translateY(6.5px) rotate(45deg);
  }

  .menu-toggle.is-active .line-2 {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  #menu-overlay {
    transform: translateY(-100%);
  }

  .menu-link {
    position: relative;
    display: inline-block;
  }

  .menu-link::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 1px;
    bottom: -4px;
    left: 0;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .menu-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
</style>

<script>
  import { gsap } from "gsap";

  // Declaración global para resolver el error de Window
  declare global {
    interface Window {
      restoreNavColor?: () => void;
    }
  }

  let isMenuOpen: boolean = false;
  let lastIntersectingSection: Element | null = null;

  function applyNavColor(nav: HTMLElement | null, colorClass: string) {
    if (!nav || !colorClass) return;
    nav.className.split(" ").forEach((cls) => {
      if (cls.startsWith("text-")) nav.classList.remove(cls);
    });
    nav.classList.add(colorClass);
  }

  function setupNavColor() {
    const nav = document.getElementById("main-nav");
    const sections = document.querySelectorAll("section[id]");

    if (!nav) return;

    const colorMap: Record<string, string> = {
      hero: "text-brown",
      "about-interior-1": "text-light",
      "about-interior-2": "text-brown",
      "about-interior-3": "text-brown",
      "contact-section": "text-brown",
    };

    const observerOptions = {
      root: null,
      rootMargin: "-10% 0px -85% 0px",
      threshold: 0,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          lastIntersectingSection = entry.target;

          if (!isMenuOpen) {
            const targetColor =
              entry.target.getAttribute("data-nav-color") ||
              colorMap[entry.target.id] ||
              "text-brown";

            applyNavColor(nav, targetColor);
          }
        }
      });
    }, observerOptions);

    sections.forEach((section) => observer.observe(section));

    window.restoreNavColor = () => {
      if (lastIntersectingSection) {
        const colorMap: Record<string, string> = {
          hero: "text-brown",
          "about-interior-1": "text-light",
          "about-interior-2": "text-brown",
          "about-interior-3": "text-brown",
          "contact-section": "text-brown",
        };
        const targetColor =
          lastIntersectingSection.getAttribute("data-nav-color") ||
          colorMap[lastIntersectingSection.id] ||
          "text-brown";
        applyNavColor(nav, targetColor);
      } else {
        applyNavColor(nav, "text-brown");
      }
    };
  }

  function setupMenu() {
    const toggles = document.querySelectorAll(".menu-toggle");
    const nav = document.getElementById("main-nav");
    const navLogo = document.querySelector("#nav-logo-center");
    const overlay = document.querySelector("#menu-overlay") as HTMLElement;
    const links = document.querySelectorAll(".menu-link");
    const footerLogo = document.querySelector(".menu-footer-logo");

    if (toggles.length === 0 || !overlay || !nav) return;

    const tl = gsap.timeline({
      paused: true,
      defaults: { ease: "expo.inOut" },
      onReverseComplete: () => {
        if (window.restoreNavColor) window.restoreNavColor();
      },
    });

    tl.set(overlay, { display: "flex" })
      .set(navLogo, { opacity: 0 })
      .to(overlay, { y: "0%", duration: 1.2 }, 0)
      .from(links, { y: 40, opacity: 0, stagger: 0.1, duration: 0.8 }, "-=0.6")
      .to(footerLogo, { y: 0, duration: 1 }, "-=0.8");

    toggles.forEach((toggle) => {
      toggle.addEventListener("click", () => {
        isMenuOpen = !isMenuOpen;

        toggles.forEach((t) => t.classList.toggle("is-active"));

        if (isMenuOpen) {
          applyNavColor(nav, "text-brown");
          tl.play();
        } else {
          tl.reverse();
        }
      });
    });

    links.forEach((link) => {
      link.addEventListener("click", () => {
        isMenuOpen = false;
        toggles.forEach((t) => t.classList.remove("is-active"));
        tl.reverse();
      });
    });
  }

  document.addEventListener("astro:page-load", () => {
    isMenuOpen = false;
    setupMenu();
    setupNavColor();
  });

  setupMenu();
  setupNavColor();
</script>
