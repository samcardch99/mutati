---
import Logo from "../assets/logo.svg";
import Logo_Large from "../assets/logo_large.svg";
import BurgerMenu from "../assets/burger_menu.svg";
---

<nav
  id="main-nav"
  class="group w-full text-brown fixed top-0 z-100 transition-colors duration-500"
>
  <div
    class="absolute inset-0 backdrop-blur-sm [mask:linear-gradient(to_bottom,black_80%,transparent_100%)] -z-10 pointer-events-none"
  >
  </div>

  <div
    class="flex justify-between items-center px-6 lg:px-24 lg:pt-12 pt-8 pb-6 relative z-200"
  >
    <button class="no-style menu-toggle cursor-pointer lg:hidden z-110">
      <svg
        width="56"
        height="16"
        viewBox="0 0 56 16"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="w-12 h-auto overflow-visible"
      >
        <rect class="line-1" width="56" height="3" rx="1.5" fill="currentColor"
        ></rect>
        <rect
          class="line-2"
          y="13"
          width="56"
          height="3"
          rx="1.5"
          fill="currentColor"></rect>
      </svg>
    </button>

    <a
      href="/ "
      class="no-style text-current absolute lg:order-1 lg:relative lg:left-auto lg:translate-x-0 left-1/2 -translate-x-1/2 w-10 h-10 md:w-12 md:h-12 lg:w-20 lg:h-20"
    >
      <Logo />
    </a>

    <a
      id="nav-logo-center"
      class="no-style hidden lg:block absolute invisible left-1/2 -translate-x-1/2 lg:w-[120px] 2xl-custom:w-[256px] 3xl-custom:w-[320px] text-inherit self-center transition-opacity"
    >
      <Logo_Large />
    </a>

    <div class="flex items-center lg:gap-12 lg:order-2">
      <a
        href="/contact"
        class="bg-current block px-6 py-2 lg:px-12 lg:py-4 rounded-full text-lg md:text-xl lg:text-4xl font-medium transition-colors duration-500"
      >
        <span
          id="apply-btn-text"
          class="text-light group-[.text-light]:text-black transition-colors duration-500"
          >APPLY</span
        >
      </a>

      <button class="no-style menu-toggle cursor-pointer hidden lg:block z-110">
        <svg
          width="56"
          height="16"
          viewBox="0 0 56 16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="w-16 h-auto overflow-visible"
        >
          <rect
            class="line-1"
            width="66"
            height="3"
            rx="1.5"
            fill="currentColor"></rect>
          <rect
            class="line-2"
            y="13"
            width="66"
            height="3"
            rx="1.5"
            fill="currentColor"></rect>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="menu-overlay"
    class="fixed inset-0 bg-[#E8E3E1] hidden flex-col items-center justify-end lg:justify-between z-105"
  >
    <div
      class="absolute top-1/2 -translate-y-1/2 lg:relative lg:top-auto lg:translate-y-0 flex flex-col items-center gap-10 lg:gap-14 lg:pt-48"
    >
      <a
        href="/"
        class="no-style menu-link text-3xl lg:text-5xl font-light tracking-tight text-brown/90"
        >Home</a
      >
      <a
        href="/about"
        class="no-style menu-link text-3xl lg:text-5xl font-light tracking-tight text-brown/90"
        >About</a
      >
      <a
        href="/#projects"
        class="no-style menu-link text-3xl lg:text-5xl font-light tracking-tight text-brown/90"
        >Projects</a
      >
      <a
        href="/contact"
        class="no-style menu-link text-3xl lg:text-5xl font-light tracking-tight text-brown/90"
        >Contact</a
      >
    </div>
    <div class="w-full px-6 lg:px-24 overflow-hidden">
      <div class="w-full border-t-2 border-brown/20 pt-10 overflow-hidden">
        <div class="menu-footer-logo w-full translate-y-full">
          <Logo_Large class="w-full pb-6 lg:pb-10" />
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  #nav-logo-center {
    transform-origin: center center;
    overflow: visible;
  }
  .line-1,
  .line-2 {
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
    transform-box: fill-box;
  }
  .menu-toggle.is-active .line-1 {
    transform: translateY(6.5px) rotate(45deg);
  }
  .menu-toggle.is-active .line-2 {
    transform: translateY(-6.5px) rotate(-45deg);
  }
  #menu-overlay {
    transform: translateY(-100%);
  }
  .menu-link {
    position: relative;
    display: inline-block;
  }
  .menu-link::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 1px;
    bottom: -4px;
    left: 0;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .menu-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
</style>

<script>
  import { gsap } from "gsap";

  declare global {
    interface Window {
      restoreNavColor?: () => void;
    }
  }

  let isMenuOpen: boolean = false;
  let lastIntersectingSection: Element | null = null;

  function applyNavColor(
    nav: HTMLElement | null,
    colorClass: string,
    applyBtnColor?: string | null,
  ) {
    if (!nav || !colorClass) return;

    // Limpiar colores previos del nav
    nav.className.split(" ").forEach((cls) => {
      if (cls.startsWith("text-")) nav.classList.remove(cls);
    });
    nav.classList.add(colorClass);

    // Lógica del botón APPLY
    const applyText = document.getElementById("apply-btn-text");
    if (applyText) {
      // Limpiamos cualquier clase de color previa inyectada manualmente
      applyText.className.split(" ").forEach((cls) => {
        if (
          cls.startsWith("text-") &&
          cls !== "text-light" &&
          cls !== "text-black"
        ) {
          applyText.classList.remove(cls);
        }
      });

      if (applyBtnColor) {
        // PRIORIDAD: Data attribute específico para Statistics
        applyText.classList.add(applyBtnColor);
      }
      // Si no hay data-apply-color, la lógica de CSS (group) se encarga mediante text-light/text-black
    }
  }

  function setupNavColor() {
    const nav = document.getElementById("main-nav");
    const sections = document.querySelectorAll("section[id]");
    if (!nav) return;

    const colorMap: Record<string, string> = {
      hero: "text-brown",
      "about-interior-1": "text-light",
      "about-interior-2": "text-brown",
      "about-interior-3": "text-brown",
      "contact-section": "text-brown",
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            lastIntersectingSection = entry.target;
            if (!isMenuOpen) {
              const targetNavColor =
                entry.target.getAttribute("data-nav-color") ||
                colorMap[entry.target.id] ||
                "text-brown";
              const targetApplyColor =
                entry.target.getAttribute("data-apply-color");

              applyNavColor(nav, targetNavColor, targetApplyColor);
            }
          }
        });
      },
      { rootMargin: "-10% 0px -85% 0px" },
    );

    sections.forEach((section) => observer.observe(section));

    window.restoreNavColor = () => {
      if (lastIntersectingSection) {
        applyNavColor(
          nav,
          lastIntersectingSection.getAttribute("data-nav-color") ||
            colorMap[lastIntersectingSection.id] ||
            "text-brown",
          lastIntersectingSection.getAttribute("data-apply-color"),
        );
      }
    };
  }

  function setupMenu() {
    const toggles = document.querySelectorAll(".menu-toggle");
    const nav = document.getElementById("main-nav");
    const overlay = document.querySelector("#menu-overlay") as HTMLElement;
    const links = document.querySelectorAll(".menu-link");

    if (toggles.length === 0 || !overlay || !nav) return;

    const tl = gsap.timeline({
      paused: true,
      onReverseComplete: () => {
        if (window.restoreNavColor) window.restoreNavColor();
      },
    });

    tl.set(overlay, { display: "flex" }).to(overlay, {
      y: "0%",
      duration: 1.2,
      ease: "expo.inOut",
    });

    toggles.forEach((toggle) => {
      toggle.addEventListener("click", () => {
        isMenuOpen = !isMenuOpen;
        toggles.forEach((t) => t.classList.toggle("is-active"));
        if (isMenuOpen) {
          applyNavColor(nav, "text-brown", null); // En el menú siempre brown
          tl.play();
        } else {
          tl.reverse();
        }
      });
    });
  }

  document.addEventListener("astro:page-load", () => {
    isMenuOpen = false;
    setupMenu();
    setupNavColor();
  });
  setupMenu();
  setupNavColor();
</script>
