---
import { Image } from "astro:assets";

// Importamos todas las imágenes
import before1 from "../assets/BeforeAfter/before1.jpg";
import after1 from "../assets/BeforeAfter/after1.jpg";
import before2 from "../assets/BeforeAfter/before2.jpg";
import after2 from "../assets/BeforeAfter/after2.jpg";
import before3 from "../assets/BeforeAfter/before3.jpg";
import after3 from "../assets/BeforeAfter/after3.jpg";
import before4 from "../assets/BeforeAfter/before4.jpg";
import after4 from "../assets/BeforeAfter/after4.jpg";
import before5 from "../assets/BeforeAfter/before5.jpg";
import after5 from "../assets/BeforeAfter/after5.jpg";

const photos = [
  { before: before1, after: after1, alt: "Interior Jet 1" },
  { before: before2, after: after2, alt: "Asiento Cuero 2" },
  { before: before3, after: after3, alt: "Cocina/Galley 3" },
  { before: before4, after: after4, alt: "Detalle Ventana 4" },
  { before: before5, after: after5, alt: "Sofá Principal 5" },
];
---

<section
  id="before-after"
  data-nav-color="text-light"
  class="w-full min-h-screen flex flex-col lg:flex-row pt-44 pb-20 justify-between items-center gap-12 lg:gap-20 text-light bg-black px-6 lg:px-24 select-none"
>
  <h2
    class="text-[clamp(2.5rem,8vw,5rem)] leading-14 italic lg:flex-[0.7] uppercase font-light"
  >
    <span
      id="label-before"
      class="cursor-pointer transition-colors duration-300">Before</span
    >
    <span class="text-gray-500">/</span>
    <span
      id="label-after"
      class="cursor-pointer text-gray-500 transition-colors duration-300"
      >After</span
    >
  </h2>

  <div
    id="comparison-container"
    class="relative h-full max-h-[70vh] w-full max-w-4xl aspect-square lg:aspect-9/16 overflow-hidden lg:flex-[1.6] cursor-ew-resize border border-white/10"
  >
    {
      photos.map((pair, index) => (
        <div
          id={`pair-${index}`}
          class={`pair-group absolute inset-0 ${index === 0 ? "z-10 opacity-100" : "z-0 opacity-0"}`}
        >
          <Image
            src={pair.after}
            alt={`After ${index + 1}`}
            class="after-img absolute inset-0 w-full h-full object-contain"
          />
          <div class="before-wrapper absolute inset-0 w-1/2 overflow-hidden z-10 border-r border-white/50">
            <Image
              src={pair.before}
              alt={`Before ${index + 1}`}
              class="before-img absolute inset-0 object-contain"
            />
          </div>
        </div>
      ))
    }

    <div
      id="slider-handle"
      class="absolute top-0 bottom-0 left-1/2 w-[2px] bg-black z-30 flex items-center justify-center -translate-x-1/2 pointer-events-none"
    >
      <div
        class="w-12 h-12 px-4 lg:w-16 lg:h-16 border border-white/50 backdrop-blur-md rounded-full flex items-center justify-center bg-black/20"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 aspect-square lg:w-8"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m18 8 4 4-4 4M6 8l-4 4 4 4"></path>
        </svg>
      </div>
    </div>
  </div>

  <h3
    class="text-center text-xl lg:text-3xl lg:ml-12 leading-loose lg:text-left w-[90%] flex-[0.7] font-light text-gray-400"
  >
    We replace outdated interiors and damaged factory leather with modern,
    bespoke designs crafted exclusively for the Holder.
  </h3>
</section>

<script>
  import { gsap } from "gsap";
  import { Draggable } from "gsap/all";

  gsap.registerPlugin(Draggable);

  const container = document.getElementById("comparison-container");
  const handle = document.getElementById("slider-handle");
  const section = document.getElementById("before-after");
  const wrappers = document.querySelectorAll(".before-wrapper");
  const pairEls = document.querySelectorAll(".pair-group");
  const labels = {
    before: document.getElementById("label-before"),
    after: document.getElementById("label-after"),
  };

  let currentIndex = 0;
  let isPaused = false;
  let currentPercent = 50;

  if (container && handle && section) {
    // Sincronizar tamaños de imagen
    const syncImages = () => {
      const { offsetWidth, offsetHeight } = container;
      const componentImages = container.querySelectorAll("img");
      componentImages.forEach((img) => {
        gsap.set(img, { width: offsetWidth, height: offsetHeight });
      });
    };

    window.addEventListener("resize", syncImages);
    syncImages();

    const updateUI = (percent: number) => {
      currentPercent = percent;
      gsap.set(wrappers, { width: `${percent}%` });
      gsap.set(handle, { left: `${percent}%` });

      if (percent > 50) {
        labels.before?.classList.remove("text-gray-500");
        labels.after?.classList.add("text-gray-500");
      } else {
        labels.before?.classList.add("text-gray-500");
        labels.after?.classList.remove("text-gray-500");
      }
    };

    const nextSlide = () => {
      if (isPaused) return;

      const prevIndex = currentIndex;
      currentIndex = (currentIndex + 1) % pairEls.length;

      const outGoing = pairEls[prevIndex];
      const inComing = pairEls[currentIndex];

      if (outGoing && inComing) {
        gsap.set(inComing, { zIndex: 5, opacity: 1 });
        gsap.set(outGoing, { zIndex: 10 });

        gsap.to(outGoing, {
          opacity: 0,
          duration: 1.5,
          ease: "power2.inOut",
          onComplete: () => {
            gsap.set(outGoing, { zIndex: 0 });
          },
        });
      }
    };

    // Observer para el auto-play
    let interval: any;
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          if (!interval) interval = setInterval(nextSlide, 4000);
        } else {
          clearInterval(interval);
          interval = 0;
        }
      },
      { threshold: 0.5 },
    );

    observer.observe(section);

    // Draggable logic
    const dragProxy = document.createElement("div");
    Draggable.create(dragProxy, {
      trigger: container,
      type: "x",
      onPress: () => {
        isPaused = true;
      },
      onRelease: () => {
        setTimeout(() => {
          isPaused = false;
        }, 2000);
      },
      onDrag: function () {
        const bounds = container.getBoundingClientRect();
        const x = this.pointerX - bounds.left;
        const percent = Math.max(0, Math.min(100, (x / bounds.width) * 100));
        updateUI(percent);
      },
    });

    const animateTo = (target: number) => {
      isPaused = true;
      const state = { val: currentPercent };
      gsap.to(state, {
        val: target,
        duration: 1.2,
        ease: "power4.inOut",
        onUpdate: () => updateUI(state.val),
        onComplete: () => {
          isPaused = false;
        },
      });
    };

    labels.before?.addEventListener("click", () => animateTo(100));
    labels.after?.addEventListener("click", () => animateTo(0));

    updateUI(50);
  }
</script>

<style>
  .before-wrapper {
    will-change: width;
    transition: none !important;
  }
  img {
    max-width: none !important;
  }
</style>
