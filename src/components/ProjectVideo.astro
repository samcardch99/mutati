---
import videoProject from "../assets/1.mp4";
import TypeWriter from "./helpers/TypeWriter.astro";
import videoProjectMobile from "../assets/avion.mp4";
---

<section
    id="project-video"
    class="relative h-screen w-full bg-bone flex flex-col justify-center items-start gap-6 md:gap-10 overflow-hidden px-6 lg:px-24 pt-36 pb-20"
>
    <video
        muted
        playsinline
        loop
        autoplay
        class="absolute inset-0 w-full h-full object-cover"
    >
        <source src={videoProjectMobile} media="(max-width: 767px)" />
        <source src={videoProject} media="(min-width: 768px)" />
    </video>
    <div class="w-fit flex flex-col mix-blend-difference">
        <h2>
            <TypeWriter
                class="text-light text-2xl md:text-4xl lg:text-6xl italic"
                phrase="The ultimate *Expression*"
            />
        </h2>
        <h2>
            <TypeWriter
                class="text-light text-2xl md:text-4xl lg:text-6xl italic"
                phrase="of a *Private Sanctuary*"
                delay={0.6}
            />
        </h2>
    </div>
    <a
        href="/projects/1"
        class="text-light text-lg md:text-xl lg:text-2xl px-6 py-3 md:px-8 md:py-4 rounded-full bg-black/80 backdrop-blur-lg border border-white/20 w-fit"
        >See Project</a
    >
</section>
