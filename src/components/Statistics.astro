---
import statistics from "../data/statistics.json";
import TextReveal from "./helpers/TextReveal.astro";
import RevealType from "./helpers/RevealType.astro";
import TypeWriter from "./helpers/TypeWriter.astro";
import PrimaryButton from "./helpers/PrimaryButton.astro";

const colors = [
  { background: "bg-brown", text: "text-bone" },
  { background: "bg-bone", text: "text-brown" },
  { background: "bg-red", text: "text-light" },
  { background: "bg-light", text: "text-red" },
];

const HOLDER = "The Holder";
const ARTIFACT = "The Artifact";
---

<section
  id="statistics-wrapper"
  data-nav-color={colors[0].text}
  class="stats-container relative"
>
  {
    statistics.map((stat, index) => {
      const isHolder = stat.title === HOLDER;
      const isArtifact = stat.title === ARTIFACT;
      const showButton = isHolder || isArtifact;

      const btnHref = isHolder
        ? "/the_holder"
        : isArtifact
          ? "/the_artifact"
          : "#";
      const buttonBgClass = colors[index].text.replace("text-", "bg-");
      const buttonTextClass = colors[index].background.replace("bg-", "text-");

      return (
        <div
          data-nav-color={stat.navColor || colors[index].text}
          data-apply-color={colors[index].background.replace("bg-", "text-")}
          id={stat.id}
          style={{ zIndex: index + 1 }}
          class={`
            stat-card
            shadow-stack-top
            relative
            h-screen w-full
            px-6 md:px-16 lg:px-24 
            flex flex-col items-start justify-center lg:justify-start 
            pt-12 md:pt-32 lg:pt-56 
            gap-8 md:gap-14 lg:gap-20 
            ${colors[index].text} ${colors[index].background}
          `}
        >
          {/* Título Principal: Ajustado para estabilidad total */}
          <h2
            class="
            text-[clamp(2.5rem,6vw,5.5rem)] 
            md:text-[clamp(3.5rem,14vw,4.5rem)] 
            lg:text-[clamp(8rem,18vw,12rem)] 
            leading-none
            font-bold 
            text-left
            w-full
            block
            overflow-visible
          "
          >
            <RevealType phrase={stat.title} delay={0.6} />
          </h2>

          <div class="h-0.5 md:h-1 w-full bg-current opacity-40 lg:opacity-100" />

          <div class="flex flex-col gap-8 md:gap-14 items-start justify-center lg:flex-row lg:justify-between lg:w-full">
            <div class="flex flex-col">
              <h3 class="text-3xl md:text-4xl lg:text-6xl font-bold tracking-tight">
                <TypeWriter phrase={stat.subtitle.split(" ")[0]} delay={0} />
              </h3>
              <h3 class="text-3xl md:text-4xl lg:text-6xl font-bold opacity-50 tracking-tight">
                <TypeWriter
                  phrase={stat.subtitle.split(" ").slice(1).join(" ")}
                  delay={0.14}
                />
              </h3>
            </div>

            <div class="w-full md:max-w-xl lg:max-w-2/5 flex flex-col lg:items-end gap-8 md:gap-10">
              <p class="w-full">
                <TextReveal
                  class="text-lg md:text-xl lg:text-4xl leading-snug md:leading-normal text-balance lg:text-end block"
                  phrase={stat.text}
                  delay={0.4}
                />
              </p>

              {showButton && (
                <div class="opacity-0 translate-y-4 stat-btn-wrapper">
                  <PrimaryButton
                    href={btnHref}
                    text="See More"
                    className={`${buttonBgClass} ${buttonTextClass} text-lg md:text-xl lg:text-3xl px-8 py-3 md:px-12 md:py-4 stat-btn`}
                  />
                </div>
              )}
            </div>
          </div>
        </div>
      );
    })
  }
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);
  ScrollTrigger.normalizeScroll(true);

  // Esto evita que la barra de direcciones "baile" mientras haces scroll dentro del pin
  ScrollTrigger.config({
    ignoreMobileResize: true,
  });

  const cards = document.querySelectorAll(".stat-card");
  const nav = document.getElementById("main-nav");
  const wrapper = document.getElementById("statistics-wrapper");

  const setVh = () => {
    // Calculamos el 1% del innerHeight actual
    let vh = window.innerHeight * 0.01;
    // Lo asignamos como propiedad al elemento raíz
    document.documentElement.style.setProperty("--vh", `${vh}px`);
  };

  // Ejecutar al cargar
  setVh();

  // Opcional: Solo actualizar en cambios de orientación, no en cada scroll
  window.addEventListener("orientationchange", setVh);

  const updateNavColor = (colorClass: string) => {
    if (!nav || !colorClass) return;
    if (wrapper) wrapper.setAttribute("data-nav-color", colorClass);

    if (!nav.classList.contains("menu-is-open")) {
      nav.className.split(" ").forEach((cls) => {
        if (cls.startsWith("text-")) nav.classList.remove(cls);
      });
      nav.classList.add(colorClass);
    }
  };

  cards.forEach((card, index) => {
    const isLast = index === cards.length - 1;
    const navColor = card.getAttribute("data-nav-color");
    const prevColor =
      index > 0 ? cards[index - 1].getAttribute("data-nav-color") : null;

    ScrollTrigger.create({
      trigger: card,
      // Pinning estable
      start: "top top",
      end: isLast ? "+=30%" : `+=${window.innerHeight}`,
      pin: true,
      pinSpacing: isLast,
      scrub: true,
      onEnter: () => updateNavColor(navColor!),
      onEnterBack: () => updateNavColor(navColor!),
      onLeaveBack: () => {
        if (prevColor) updateNavColor(prevColor);
      },
    });

    const btnWrapper = card.querySelector(".stat-btn-wrapper");
    if (btnWrapper) {
      gsap.to(btnWrapper, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: "power3.out",
        delay: 0.7,
        scrollTrigger: {
          trigger: card,
          start: "top 10%",
          toggleActions: "play none none reverse",
        },
      });
    }
  });
</script>

<style>
  .stat-card {
    will-change: transform;
    /* Prevenir gaps de sub-píxeles */
    outline: 1px solid transparent;
  }

  .shadow-stack-top {
    box-shadow: 0 -15px 40px -10px rgba(0, 0, 0, 0.85);
  }

  /* Aseguramos que el contenedor de estadísticas no tenga scroll horizontal inesperado */
  #statistics-wrapper {
    overflow-x: hidden;
  }
</style>
